# Production Environment Configuration for Open SWE Backend
# Copy this file to .env and fill in your actual values

# =============================================================================
# LangSmith Configuration (Optional - for tracing and monitoring)
# =============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=open-swe-production

# =============================================================================
# LLM Provider Configuration (Choose one or more)
# =============================================================================

# Anthropic (Recommended - prompts are optimized for Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (Alternative)
OPENAI_API_KEY=your_openai_api_key_here

# Google AI (Alternative)
GOOGLE_GENAI_API_KEY=your_google_ai_api_key_here

# =============================================================================
# Sandbox Environment (Daytona)
# =============================================================================
DAYTONA_API_KEY=your_daytona_api_key_here

# =============================================================================
# Web Scraping (Firecrawl)
# =============================================================================
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# =============================================================================
# GitHub App Configuration
# =============================================================================
GITHUB_APP_NAME=your_github_app_name
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_content_here\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TRIGGER_USERNAME=your_github_username_for_triggers

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8123
NODE_ENV=production

# Your Vultr server's public URL (replace with your actual domain)
OPEN_SWE_APP_URL=https://your-domain.com

# =============================================================================
# Security
# =============================================================================
# Generate a strong random key for encrypting secrets
ENCRYPTION_KEY=your_32_character_encryption_key_here

# =============================================================================
# Additional Production Settings
# =============================================================================
# Enable HTTPS redirect
FORCE_HTTPS=true

# CORS settings for your frontend
CORS_ORIGIN=https://your-vercel-frontend.vercel.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Logging and Monitoring
# =============================================================================
# Log level for production (debug, info, warn, error)
LOG_LEVEL=warn

# Health check configuration
HEALTH_CHECK_TIMEOUT=5000

# Metrics and monitoring
METRICS_ENABLED=true
TRACING_ENABLED=true

# =============================================================================
# Performance Configuration
# =============================================================================
# Server host binding
HOST=0.0.0.0

# Request timeout settings
REQUEST_TIMEOUT=30000
KEEP_ALIVE_TIMEOUT=5000
MAX_CONCURRENT_REQUESTS=100

# Webhook Configuration
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_MAX_RETRIES=3
WEBHOOK_BATCH_SIZE=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_CACHING=true
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_RATE_LIMITING=true
ENABLE_HEALTH_CHECKS=true
ENABLE_REQUEST_LOGGING=true
ENABLE_ERROR_REPORTING=true